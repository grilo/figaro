{
  "name": "figaro",
  "version": "1.3.3",
  "description": "Local-first Markdown workspace for notes, planning, diagrams, and printable documents",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:unit": "bash tests/release/prepare-release.test.sh && jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:pdf": "playwright test",
    "lint": "eslint frontend/js",
    "lint:fix": "eslint frontend/js --fix",
    "vendor": "bash scripts/vendor.sh",
    "vendor:markdown": "node scripts/vendor-markdown-renderer.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "esbuild": "0.28.1",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "^\\./test_setup\\.js$": "<rootDir>/tests/frontend/support/test_setup.js",
      "^\\.\\./frontend/(.*)$": "<rootDir>/frontend/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@codemirror/legacy-modes/mode/(.*)\\.js$": "<rootDir>/frontend/vendored/codemirror/legacy-modes/mode/$1.js",
      "^@codemirror/(.*)$": "<rootDir>/frontend/vendored/codemirror/$1/index.js",
      "^@lezer/(.*)$": "<rootDir>/frontend/vendored/lezer/$1/index.js",
      "^@replit/(.*)$": "<rootDir>/frontend/vendored/@replit/$1/dist/index.js",
      "^@uiw/codemirror-extensions-color$": "<rootDir>/frontend/vendored/@uiw/codemirror-extensions-color/index.js",
      "^style-mod$": "<rootDir>/frontend/vendored/style-mod/index.js",
      "^crelt$": "<rootDir>/frontend/vendored/crelt/index.js",
      "^w3c-keyname$": "<rootDir>/frontend/vendored/w3c-keyname/index.js"
    },
    "testMatch": [
      "<rootDir>/tests/frontend/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/frontend/support/test_setup.js"
    ],
    "collectCoverageFrom": [
      "frontend/js/**/*.js",
      "!tests/**/*.js"
    ]
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "overrides": {
    "babel-plugin-istanbul": "8.0.0",
    "test-exclude": "8.0.0",
    "glob": "13.0.6",
    "jsdom": "27.4.0"
  },
  "dependencies": {
    "@babel/runtime": "8.0.0",
    "@mdit/plugin-anchor": "1.1.1",
    "@mdit/plugin-footnote": "1.0.1",
    "@mdit/plugin-katex": "1.0.1",
    "@mdit/plugin-mark": "2.0.0",
    "@mdit/plugin-sub": "1.0.2",
    "@mdit/plugin-sup": "1.0.2",
    "@mdit/plugin-tasklist": "1.0.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@uiw/codemirror-extensions-color": "4.25.11",
    "codemirror-live-markdown": "^0.5.1-alpha.1",
    "codemirror-markdown-tables": "1.0.0",
    "katex": "^0.17.0",
    "lucide": "1.24.0",
    "markdown-it": "^14.3.0",
    "playwright": "^1.61.1"
  }
}
